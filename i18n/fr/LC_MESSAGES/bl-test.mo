msgid ""
msgstr ""
"Project-Id-Version: bl-test\n"
"Language: fr\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid ""
"Main options:\n"
"  -h, --help               show help and exit/return\n"
"  -V, --version            show version and exit/return"
msgstr ""
"Options principales :\n"
"  -h, --help               affiche l'aide et quitte / retourne\n"
"  -V, --version            affiche la version et quitte / retourne"

msgid "Usage: %s [MAIN_OPTIONS]... ACTION [OPTIONS]... [ARGUMENTS]..."
msgstr "Utilisation : %s [OPTIONS_PRINCIPALES]... ACTION [OPTIONS]... [ARGUMENTS]..."

msgid "Usage: source %s [MAIN_OPTIONS]..."
msgstr "Utilisation : source %s [OPTIONS_PRINCIPALES]..."

msgid "%s: unrecognized option '%s'\n\nTry '%s --help' for more information.\n"
msgstr "%s : option non reconnue « %s »\n\nEssayez « %s --help » pour plus d’informations.\n"

msgid "Actions:"
msgstr "Actions :"
