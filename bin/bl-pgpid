### internal functions ###

_bl_pgpid_parseoptions() {
	local npp=$# frontend
	for ((;$#;)) ; do
		case "$1" in
			-f|--frontend) shift; frontend="$1";; # Will be passed to bl-interactive
			-h|--help) printf "%s\n%s%s" "$BL_PGPID_usage" "$BL_PGPID_chelpmsg" "$BL_PGPID_shelpmsg" ; return 1 ;;
			-V|--version) printf "%s %s\n" "$BL_PGPID_NAME" "$BL_PGPID_VERSION" ; return 1 ;;
			--) shift ; break ;;
			-*) printf "%s: unrecognized option '%s'\n\nTry '%s --help' for more information.\n" "$BL_PGPID_NAME" "$1" "$BASH_SOURCE" >&2 ; return 2 ;;
			*) break ;;
		esac
		shift
	done
	BL_PGPID_NOPTIONS=$((npp-$#))
# shellcheck source=bl-interactive
	if [[ "$frontend" ]] ; then
		source "$(dirname "$BASH_SOURCE")"/bl-interactive --frontend "$frontend" --
	else
		source "$(dirname "$BASH_SOURCE")"/bl-interactive --
	fi
}

_bl_icao9303_mrz_checkdigit() {
	local helpmsg="Usage: $FUNCNAME STRING [EXPECTED_RESULT]
If there is no second arg: output calculated check digit from [0-9A-Z<]* string
else return non-zero if EXPECTED_RESULT differs from calculated check digit.
"
	for ((;$#;)) ; do
		case "$1" in
			-h|--h*) echo "$helpmsg" ; return ;;
			-V|--version) printf "%s %s\n" "$FUNCNAME" "$BL_PGPID_VERSION" ; return ;;
			--) shift ; break ;;
			-*) echo -e "$FUNCNAME: Error: Unrecognized option/parameters $1\n$helpmsg" >&2 ; return 2 ;;
			*) break ;;
		esac
		shift
	done

	local char sum=0 weight=(7 3 1)
	for ((i=0;i<${#1};i++)) ; do
		char=${1:$i:1}
		case $char in
			[0-9]) ((sum+=char*${weight[$((i%3))]})) ;;
			[A-Z]) ((sum+=($(printf "%d" "'$char'")-55)*${weight[$((i%3))]})) ;;
		esac
	done

	if ! [[ "$2" ]] ; then
		echo $((sum%10))
	else
		[[ "$2" == $((sum%10)) ]]
		return $?
	fi
}

_bl_icao9303_mrz_analyse() {
	local helpmsg="Usage: $FUNCNAME [Options] AANAME MRZ
Options:
  -u, --uncheck                Dont verify checksums
Analyse a Machine Readable Zone and fill the associative array named AANAME
"

	local uncheck
	for ((;$#;)) ; do
		case "$1" in
			-u|--uncheck) uncheck="--uncheck" ;;
			-h|--h*) echo "$helpmsg" ; return ;;
			-V|--version) printf "%s %s\n" "$FUNCNAME" "$BL_PGPID_VERSION" ; return ;;
			--) shift ; break ;;
			-*) echo -e "$FUNCNAME: Error: Unrecognized option/parameters $1\n$helpmsg" >&2 ; return 2 ;;
			*) break ;;
		esac
		shift
	done

	local -n doc=$1
	shift
	local ch mrz=$*
	mrz=${mrz//[$'\t\r\n ']}

	if [[ ${mrz:0:1} != P ]] ; then
		# Only ICAO-9303 (ISO/IEC-7501-1) passport are yet supported.
		printf "%s: Error: Unsupported MRZ '%s...'." "$FUNCNAME" "${mrz:0:1}"
		return 1
	fi
	if [[ ${#mrz} != 88 ]] ; then
		printf "%s: Error: Invalid MRZ lenght: %d." "$FUNCNAME" "${#mrz}"
		return 1
	fi

	doc=(
		[type]=${mrz:0:2}
		[country]=${mrz:2:3}
		[all_names]=${mrz:5:39}
		[number]=${mrz:44:9}
		[check_number]=${mrz:53:1}
		[nationality]=${mrz:54:3}
		[date_of_birth]=${mrz:57:6}
		[check_date_of_birth]=${mrz:63:1}
		[sex]=${mrz:64:1}
		[expiration_date]=${mrz:65:6}
		[check_expiration_date]=${mrz:71:1}
		[personal_number]=${mrz:72:14}
		[check_personal_number]=${mrz:86:1}
		[composite]="${mrz:44:10}${mrz:57:7}${mrz:65:20}"
		[check_composite]=${mrz:87:1}
	)

	[[ -z "$uncheck" ]] || return 0

	for ch in number date_of_birth expiration_date personal_number composite ; do
		doc[checked_$ch]=$(_bl_icao9303_mrz_checkdigit "${doc[$ch]}")
		doc[valid_$ch]=$( [[ ${doc[checked_$ch]} == ${doc[check_$ch]} ]] && echo true || echo false )
		${doc[valid_$ch]} || printf "%s: Warning: %s checksum -> %s. Should be %s.'\n" "$FUNCNAME" "$ch" "${doc[check_$ch]}" "${doc[checked_$ch]}" >&2
	done
}

### public functions / program actions ###

bl_pgpid_mrz_to_u4() {
	local name
	((BL_PGPID_isprogram)) && name="$BL_PGPID_NAME ${FUNCNAME:9}" || name="$FUNCNAME"
	local usage="Usage: $name [OPTIONS]... MRZ..."
	local helpmsg="
Convert the Machine Readable Zone of an icao9303 passport to an udid4 (aka 'u4')

Option:
  -u, --uncheck                Dont verify checksums
  -d, --birth-date YYYY-MM-DD  Birth date, expected format : Year-Month-Day (for people born 100+ years ago)

WARNING: mrz data may be irrelevant to generate udid4. eg:
         * Surname or given names may be incomplete (cut bc exceed mrz size)
         * Surname or given names may differs from those given at birth (marriage, gender change, etc.)
         * Surname or given names transliteration may have change over time
         * Year of birth date is only written with 2 digits (and people may live longer than 100 years)
         * Humans may have done error on birth date, surname or given names.
By the way, there are ~80% chance that an icao9303 MRZ allow to generate a correct udid4.
People have to check, and fix when NOK.
"

	local gdate uncheck
	for ((;$#;)) ; do
		case "$1" in
			-d|--birth-d*) shift ; gdate=$(sed ' s,[^0-9],,g ' <<<"$1") ;; # keep only [0-9] from given input
			-u|--uncheck) uncheck="--uncheck" ;;
			-h|--h*) echo "$helpmsg" ; return ;;
			-V|--version) printf "%s %s\n" "$FUNCNAME" "$BL_PGPID_VERSION" ; return ;;
			--) shift ; break ;;
			-*) echo -e "$name: Error: Unrecognized option/parameters $1\n$helpmsg" >&2 ; return 2 ;;
			*) break ;;
		esac
		shift
	done

	local -A mrza=()
	local allnames bdate countrycode coordinates

	if ! _bl_icao9303_mrz_analyse $uncheck mrza "$@" ; then
		printf "%s: Error: Can't analyse given Machine Readable Zone (ICAO9303)\n" "$FUNCNAME" >&2
			return 1
	fi

	if ! allnames=$(LC_COLLATE="C.UTF-8" grep -o "[A-Z]\{1,32\}<<[A-Z]\{1,32\}<[A-Z]\{0,32\}<" <<<"${mrza[all_names]}" ) ; then
		printf "%s: Error: no valid and complete surname and given names extracted from '%s'\n" "$FUNCNAME" "${mrza[all_names]}" >&2
		return 1
	fi

	countrycode="${mrza[country]}"
	coordinates="${BL_PGPID_COORDINATES[$countrycode]: 0:14}"
	if ! [[ "$coordinates" =~ ^${BL_PGPID_CO_REGEX}$ ]] ; then
		printf "%s: Error: Invalid coordinates (%s) for country '%s'\n" "$FUNCNAME" "$coordinates" "$countrycode" >&2
		return 1
	fi

	if [[ "$gdate" ]] ; then
		((${#gdate}==8)) || printf "%s: Notice: Invalid lenght for birth date '%s'\n" "$FUNCNAME" "$gdate" >&2
	else
		gdate="${mrza[date_of_birth]}"
	fi
	if ! bdate=$(date --date "${gdate}" +"%Y-%m-%d" ) ; then
		printf "%s: Error: Can't reformat birthdate '%s'\n" "$FUNCNAME" "$gdate" >&2
		return 1
	fi

	echo "$(printf "${allnames}${bdate}" | md5sum | xxd -r -p | basenc --base64url | sed 's/==$//')$coordinates"
}

bl_pgpid_gen_u4() {
	local name
	((BL_PGPID_isprogram)) && name="$BL_PGPID_NAME ${FUNCNAME:9}" || name="$FUNCNAME"
	local usage="Usage: $name [OPTIONS]... [MRZ]..."
	local helpmsg="
Generate udid4. Missing input is asked interactively.
You may pass the Machine Readable Zone of an international passport as argument, but there are ~20% chances that generated udid4 is incorrect.

Options:
  -s, --surname SURNAME            Surname/family name at birth
  -g, --given-names GIVEN_NAMES    Given names at birth, separated by space ' ' or comma ',' or hyphen '-'.
  -d, --birth-date YYYY-MM-DD      Birth date, expected format : Year-Month-Day.
  -c, --birth-country COUNTRY_CODE 3 letters country code of birth place: FRA, GBR, ...
  -v, --verify                     Ask for verification
"
	local sname gname translit bdate bcountry verify=""
	for ((;$#;)) ; do
		case "$1" in
			-s|--s*)
				shift ; sname=$1 ;;
			-g|--g*)
				shift ; gname=$1 ;;
			-d|--birth-d*)
				shift ; bdate=$1 ;; # $bdate is always be passed as an argument to bl_pgpid_mrz_to_u4()
			-c|--birth-c*)
				shift ; bcountry=$1 ;;
			-v|--verify) verify=1 ;;
			-h|--help) printf "%s\n%s\n" "$usage" "$helpmsg" ; return ;;
			-V|--version) printf "%s %s\n" "$FUNCNAME" "$BL_PGPID_VERSION" ; return ;;
			--) shift ; break ;;
			-*) printf "%s: Error: unrecognized option '%s'\nTry '%s --help' for more information.\n" "$FUNCNAME" "$1" "$name" >&2 ; return 2 ;;
			*) break ;;
		esac
		shift
	done

	# If a Machine Readable Zone is passed as arguments
	if [[ "$1" ]] ; then
		local -A mrza=()
		if ! _bl_icao9303_mrz_analyse mrza "$@" ; then
			printf "%s: Warning: Can't analyse given Machine Readable Zone (ICAO9303)\n" "$FUNCNAME" >&2
		else
			[[ "$sname" ]] || sname=$(tr '<' ' ' <<<"${mrza[all_names]%%<<*}")
			[[ "$gname" ]] || gname=$(sed ' s,<*$,,g ; s,<, , ' <<<"${mrza[all_names]#*<<}")
			[[ "$bdate" ]] || {	bdate="${mrza[date_of_birth]}" ; bdarg="--birth-date" ; }
			[[ "$bcountry" ]] || bcountry="${mrza[country]}"
		fi
	fi

	[[ "$sname" ]] || sname=$(bl_input "Birth surname (family name)")
	[[ "$gname" ]] || gname=$(bl_input "Birth names (given names)")
	[[ "$bdate" ]] || bdate=$(bl_input "Birth date (YYYY-MM-DD)")
	[[ "$bcountry" ]] || bcountry=$(bl_input --default "FRA" "Birth country (3 letter code)")

	while [[ "$verify" ]] ; do
		! bl_yesno --default=no --text \
	"
	Surname at birth:     ${sname}
	Given names at birth: ${gname}
	Date of birth:        ${bdate}
	Country of birth:     ${bcountry}
	" \
			"Is that correct" || break

		sname=$(bl_input --default "${sname^^}" "Birth surname (family name)")
		gname=$(bl_input --default "${gname}" "Birth names (given names)")
		bdate=$(bl_input --default "${bdate}" "Birth date (YYYY-MM-DD)")
		bcountry=$(bl_input --default "${bcountry}" "Birth country (3 letter code)")
	done

	sname=$(sed 's,[ ;,<-]\+,<,g'<<<"$sname" ) # replace and squeeze some word separators
	translit=$(iconv -f utf-8 -t ascii//TRANSLIT <<<"$sname") # transliterate (according to iconv), may differ from Passport transliterations.
	if [[ "$translit" != "$sname" ]] ; then
		printf "%s: Warning: '%s' has been transliterated to '%s'. It may be WRONG !\n" "$FUNCNAME" "$sname" "$translit" >&2
		sname="$translit"
	fi
	sname="${sname^^}" # uppercase

	gname=$(sed 's,[ ;,<-]\+,<,g'<<<"$gname" )
	translit=$(iconv -f utf-8 -t ascii//TRANSLIT <<<"$gname")
	if [[ "$translit" != "$gname" ]] ; then
		printf "%s: Warning: '%s' has been transliterated to '%s'. It may be WRONG !\n" "$FUNCNAME" "$gname" "$translit" >&2
		gname="$translit"
	fi
	gname="${gname^^}"

	if ! fakemrz="P<${bcountry}$(LC_COLLATE="C.UTF-8" grep -o "[A-Z]\{1,32\}<<[A-Z]\{1,32\}<[A-Z]\{0,32\}<" <<<"${sname}<<$gname<<" )" ; then
		printf "%s: Error: only [A-Z] characters allowed in names.\n" "$FUNCNAME" >&2
		return 1
	fi
	fakemrz+="<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<"

	bl_pgpid_mrz_to_u4 --uncheck --birth-date "$bdate" "${fakemrz: 0:88}"
}


bl_pgpid_2num() {
	local name
	((BL_PGPID_isprogram)) && name="$BL_PGPID_NAME ${FUNCNAME:9}" || name="$FUNCNAME"
	local usage="Usage: $name [OPTIONS]... SIZE [FILE]"
	local helpmsg="
Shrink input data to a number limited by SIZE.
Usefull to make hash distributed into a lesser space whith (uncommon) SIZE not matching 2^n.
This function XOR sucessive 64bits words of raw input, and apply 'modulo SIZE' at the end.
Then Maximum SIZE is 2^64-1. (And avoid to get close to this limit if you need a good number dispatching).
About encodings: check basenc manual from GNU coreutils.

Options:
  -i, --input-encoding ENCODING  Eg: raw(default), base64, base64url, base32, base32hex, base16, base2msbf or base2lsbf.
  -g, --ignore-garbage           When decoding (a 'baseXXX' input), ignore non-alphabet characters.
  -o, --output-encoding ENCODING Eg: raw, base64, base64url, base32, base32hex, base16, base10(default), base2msbf or base2lsbf.
"
	local ienc="raw" oenc="base10" iextropts=""
	for ((;$#;)) ; do
		case "$1" in
			-i|--input-encoding)
				shift ; ienc=$1 ;;
			-o|--ouput-encoding)
				shift ; oenc=$1 ;;
			-g|--ignore-garbage)
				iextraopts+="--ignore-garbage " ;;
			-h|--help) printf "%s\n%s\n" "$usage" "$helpmsg" ; return ;;
			-V|--version) printf "%s %s\n" "$FUNCNAME" "$BL_PGPID_VERSION" ; return ;;
			--) shift ; break ;;
			-*) printf "%s: Error: unrecognized option '%s'\nTry '%s --help' for more information.\n" "$FUNCNAME" "$1" "$name" >&2 ; return 2 ;;
			*) break ;;
		esac
		shift
	done

	if ! [[ "$1" =~ ^[1-9][0-9]* ]] ; then
		printf "$usage\n" >&2
		return 2
	fi
	size="$1"
	shift

	local decoder offset hex dec=0 char encoder
	case "$ienc" in
		raw)
			decoder="cat" ;;
		base64|base64url|base32|base32hex|base16|base2msbf|base2lsbf)
			decoder="basenc --decode --$ienc $iextraopts" ;;
		*)
			printf "%s: Error: unrecognized encoding '%s'\nTry '%s --help' for more information.\n" "$FUNCNAME" "$ienc" "$name" >&2 ; return 2 ;;
	esac

	while read offset hex char; do
		#printf "%016X\n" $((0x$hex))
		dec=$((0x$hex ^ dec))
		#printf "%016X\n" $((dec))
	done < <( $decoder "$@" | xxd -c 8 -g 0 )

	# Simple dec=$((dec%size)) doesn't work as (( builtin use only signed integer, then number > 0x0fff ffff ffff ffff are negative
	# And with negative number '%', which is the reminder operator, differs from the mathematical modulo operation.
	# see https://torstencurdt.com/tech/posts/modulo-of-negative-numbers/
	dec=$(( ((dec % size) + size) % size ))

	hex=$(printf "%02X\n" $dec)

	case "$oenc" in
		raw)
			echo "$hex" | xxd -r -p ;;
		base10)
			printf "%u\n" "$dec" ;;
		base16)
			echo "$hex" ;;
		base64|base64url|base32|base32hex|base2msbf|base2lsbf)
			echo "$hex" | xxd -r -p | basenc --$oenc ;;
		*)
			printf "%s: Error: unrecognized encoding '%s'\nTry '%s --help' for more information.\n" "$FUNCNAME" "$ienc" "$name" >&2 ; return 2 ;;
	esac
}

bl_pgpid_gen_uid() {
#  Since linux kernel 2.6, user ID (uid) are coded on 32 bit, so it should range from 0 (root) to 2^32-1 = 4294967295
#  On older unix systems it was coded on 16 bit (0 to 65535) :
#  - 0: root
#  - under 1000: "system" users
#  - 1000: Main "human" user (also often: first administrator)
#  - above 1000: other "human" users
#  - up to 65534, which is use by convention by the user 'nobody'.
#
#  tests:
#  - $ LANG=C sudo useradd -u 4294967295 test
#    useradd: invalid user ID '4294967295'
#    Return value $?: 3 (error)
#  - $ LANG=C sudo useradd -u 4294967294 test
#    useradd warning: test's uid -2 outside of the UID_MIN 1000 and UID_MAX 60000 range.
#    Return value $?: 0 (OK)
#
#   If we let 4294967294, 4294967293 and id under 2^18 (< 262144), for some futur usage/convention,
#   then we can use range 262144 to 4294967292, to get an almost unique Unix User ID from unique foopgp User ID (udid4,...)
#
#   Confer https://www.debian.org/doc/debian-policy/ch-opersys.html#users-and-groups
#
#   Which make 4294705148 slots, ~= about half of the actual human population (~8 billions).
#   Constants: BL_PGPID_XUID_MIN and BL_PGPID_XUID_MAX

	local name
	((BL_PGPID_isprogram)) && name="$BL_PGPID_NAME ${FUNCNAME:9}" || name="$FUNCNAME"
	local usage="Usage: $name [OPTIONS] [UDID4]"
	local helpmsg="
Generate a 32bit Unix User ID, from 2^18 to (2^32)-4 ([$BL_PGPID_XUID_MIN,$BL_PGPID_XUID_MAX]).
If UDID4 is not given, it will ask for surname, names and date of birth.
You may pass a foopgp UDID4 as an argument, as ouput is calculated from it.

Options:
	-f, --free-input            Accept any input, not only string containing a foopgp UDID4.
"
	local freeinput=0 str_in u4h num
	for ((;$#;)) ; do
		case "$1" in
			-f|--free-input) freeinput=1 ;;
			-h|--help) printf "%s\n%s\n" "$usage" "$helpmsg" ; return ;;
			-V|--version) printf "%s %s\n" "$FUNCNAME" "$BL_PGPID_VERSION" ; return ;;
			--) shift ; break ;;
			-*) printf "%s: Error: unrecognized option '%s'\nTry '%s --help' for more information.\n" "$FUNCNAME" "$1" "$name" >&2 ; return 2 ;;
			*) break ;;
		esac
		shift
	done

	if [[ "$1" ]] ; then
		# If an input is passed as arguments
		str_in="$*"
	else
		str_in="$(bl_pgpid_gen_u4 --birth-country FRA)=="
		freeinput=0 # --free-input is non-sense if no imput has been given in $*.
	fi

	if ((freeinput)) ; then
		u4h="$(echo "$str_in" | md5sum | xxd -r -p | basenc --base64url)"
		echo "$u4h"
	elif [[ "$str_in" =~ ${BL_PGPID_U4H_REGEX} ]] ; then
		u4h="${BASH_REMATCH[0]}=="
	else
		printf "%s: Error: No udid4 (hash) found in '%s'...\n" "$FUNCNAME" "${str_in: 0:44}" >&2
		return 2
	fi

	num=$(bl_pgpid_2num --input-encoding base64url $((BL_PGPID_XUID_MAX - BL_PGPID_XUID_MIN)) <<<"$u4h") && echo $((num + BL_PGPID_XUID_MIN))
}

bl_pgpid_gen_key() {
	local name
	((BL_PGPID_isprogram)) && name="$BL_PGPID_NAME ${FUNCNAME:9}" || name="$FUNCNAME"
	local usage="Usage: $name [OPTIONS]... EMAIL"
	local passphrase=$(date -I)
	local helpmsg="
Generate an OpenPGP key pair (public and secret) according to foopgp standards.
Output 3 lines for each fingerprints :
* main key (Sign Certify)
* decryption key (Encrypt)
* authentication key (Auth)

Options:
  -n, --name PSEUDONYM             Common name or pseudonym (default: first part of email)
  -c, --comment UDID4              Comment field, expect an udid4, regex: ${BL_PGPID_U4_REGEX}
  -p, --passphrase PASSPHRASE      Passphrase to (symetric) encrypt secret part of OpenPGP key (default: ${passphrase})
  -e, --expiration YEARS           Number of years before certificate expiration (default: 11 -> $(date -I -d "+11 years"))
  -k, --keyserver KEYSERVER        Prefered OpenPGP certificate server (default: hkp://keys.foopgp.org)
  -H, --homedir GNUPGHOME          GnuPG home directory (default: ~/.gnupg). Environnement variable: \$GNUPGHOME
"
	local email pseudo comment keyserv="hkp://keys.foopgp.org" gpghome
	local gpghome=${GNUPGHOME:-~/.gnupg}
	local expire=11 verify=""
	for ((;$#;)) ; do
		case "$1" in
			-n|--name*)
				shift ; pseudo=$1 ;;
			-c|--comment)
				shift ; comment=$1 ;;
			-p|--passphrase)
				shift ; passphrase=$1 ;;
			-e|--expir*)
				shift ; expire=$1 ;;
			-k|--keyserver)
				shift ; keyserv=$1 ;;
			-H|--homedir)
				shift ; gpghome=$1 ;;
			-v|--verify) verify=1 ;;
			-h|--help) printf "%s\n%s\n" "$usage" "$helpmsg" ; return ;;
			-V|--version) printf "%s %s\n" "$FUNCNAME" "$BL_PGPID_VERSION" ; return ;;
			--) shift ; break ;;
			-*) printf "%s: Error: unrecognized option '%s'\nTry '%s --help' for more information.\n" "$FUNCNAME" "$1" "$name" >&2 ; return 2 ;;
			*) break ;;
		esac
		shift
	done

	if ! [[ "$1" =~ ^${BL_INTERACTIVE_EMAIL_REGEX}$ ]] ; then
		printf "$usage\n" >&2
		return 2
	fi
	email="$1"
	shift

#TODO: implement --verify to check input and ask when incoherent or missing.
#TODO (also): check gpg version, because we use some recent feature, and compatibility may change (tested with gpg (GnuPG) 2.2.27 libgcrypt 1.8.8)

	[[ "$pseudo" ]] || pseudo=${email%%@*}

	if [[ "$comment" =~ ${BL_PGPID_U4_REGEX} ]] ; then
		comment="u4=${BASH_REMATCH[0]}"
	elif [[ "$comment" =~ ${BL_PGPID_N2_REGEX} ]] ; then
		comment="n2=${BASH_REMATCH[0]}"
	elif [[ -z "$comment" ]] ; then
		comment="generated with $name"
	else
		printf "%s: Notice: unexpected comment: %s\n" "$FUNCNAME" "$comment" >&2
	fi

	local genkey_batch="
%echo Generating OpenPGP key for ${email}
Key-Type: eddsa
Key-Curve: Ed25519
Key-Usage: cert sign
Subkey-Type: ecdh
Subkey-Curve: Curve25519
Subkey-Usage: encrypt
Name-Real: ${pseudo}
Name-Comment: ${comment}
Name-Email: ${email}
Expire-Date: $(date -I -d "+$expire years")
Passphrase: ${passphrase}
Keyserver: ${keyserv}
# Do a commit here, so that we can later print 'done' :-)
%commit
"

	gpg --homedir "$gpghome" --batch --generate-key --allow-freeform-uid <<<"$genkey_batch" || return $?

	# get first 2 fprs
	local fprs
	fprs=($(gpg --homedir "$gpghome" --list-secret-keys --with-colons "$email" | sed -n 's,^fpr:.*:\([[:xdigit:]]\{40\}\):,\1,p')) || return $?

	# Generate and add auth key...
	gpg --homedir "$gpghome" --batch --passphrase "${passphrase}" --pinentry-mode loopback --quick-add-key ${fprs[0]} ed25519 auth ${expire}y || return $?

	# output all (3) fingerprints, first fingerprint should be the one of the main key
	gpg --homedir "$gpghome" --list-secret-keys --with-colons "$email" | sed -n 's,^fpr:.*:\([[:xdigit:]]\{40\}\):,\1,p'
}


### General Help Messages ###

if [[ "$BASH_SOURCE" == "$0" ]] ; then
	# run as a program
	declare -r BL_PGPID_isprogram=1

	BL_PGPID_usage="Usage: $BASH_SOURCE [OPTIONS]... ACTION [ACTION_ARGUMENTS]..."
	BL_PGPID_shelpmsg="
  -h, --help               show this help and exit
  -V, --version            show version and exit

Actions:
$(for f in "${BL_PGPID_FUNCTIONS[@]}" ; do printf "   %-19s%s\n" "${f:9}" "$($f --help | sed -n '/^$/{n;p;q}')" ; done)

All actions support a --help options, eg:
$ $BASH_SOURCE ACTION --help

$BL_PGPID_NAME is also bash library, see:
$ source $BASH_SOURCE --help
"
else
	# run as a library (source $0)

	BL_PGPID_usage="Usage: source $BASH_SOURCE [OPTIONS]..."

	BL_PGPID_shelpmsg="
      --bash-completion    set completion for $BASH_SOURCE program and return (without loading anything else)

Functions:
$(for f in "${BL_PGPID_FUNCTIONS[@]}" ; do printf "   %-19s%s\n" "$f" "$($f --help | sed -n '/^$/{n;p;q}')" ; done)

Reminder: when used as a library, all functions calls share the same environment variables, i.e. the same global options.
"
fi

BL_PGPID_chelpmsg="
Generate foopgp identifiers, like *udid4* to identify world-wide humans, or a fixed Unix User ID for each of them.

Options:
  -f, --frontend PROGRAM   select a frontend program {NONE,whiptail,dialog} (environment var: BL_INTERACTIVE_FRONTEND)"

### Init ###

# Parse Options
_BL_PGPID_RETVAL=0
_bl_pgpid_parseoptions "$@" || _BL_PGPID_RETVAL=$?

# Do nothing else if sourced
[[ "$BASH_SOURCE" == "$0" ]] || return $_BL_PGPID_RETVAL

[[ "$_BL_PGPID_RETVAL" != "1"  ]] || exit 0
[[ "$_BL_PGPID_RETVAL" < 2 ]] || exit $_BL_PGPID_RETVAL

### Run ###
set -e
shift $BL_PGPID_NOPTIONS
if function=$(grep -o "\<bl_pgpid_$1\>" <<< "${BL_PGPID_FUNCTIONS[@]}") ; then
	shift
	$function "$@"
	exit $?
else
	printf "%s: unrecognized action '%s'\n\nTry '%s --help' for more information.\n" "$BL_PGPID_NAME" "$1" "$BASH_SOURCE" >&2
	exit 2
fi

